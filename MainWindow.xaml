<Window x:Class="HotelApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hệ Thống Quản Lý Khách Sạn - Demo Range Controls" Height="600" Width="450" Background="#F0F2F5">

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">


        <StackPanel Margin="20">
            <TextBlock Text="QUẢN LÝ PHÒNG 302" FontSize="22" FontWeight="Bold" Foreground="#1A73E8" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <GroupBox Header="1. Chính sách giảm giá (Slider)" Padding="15" Margin="0,0,0,20" Background="White">
                <StackPanel>
                    <TextBlock Text="Kéo để chọn mức chiết khấu cho khách VIP:" Margin="0,0,0,10" FontStyle="Italic"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Slider Name="SliderDiscount" Minimum="0" Maximum="50" Value="0" 
                            TickFrequency="5" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                            ValueChanged="SliderDiscount_ValueChanged"/>
                        <TextBlock Name="txtDiscount" Grid.Column="1" Text="0%" FontWeight="Bold" FontSize="16" Foreground="Red" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="2. Trạng thái dọn phòng (ProgressBar)" Padding="15" Margin="0,0,0,20" Background="White">
                <StackPanel>
                    <TextBlock Text="Tiến độ vệ sinh hiện tại:" Margin="0,0,0,10"/>
                    <ProgressBar Name="PbHousekeeping" Height="15" Minimum="0" Maximum="100" Value="0" Foreground="#2ECC71"/> 
                    <Grid Margin="0,15,0,0">
                        <Button Content="Bắt đầu dọn" Click="BtnStartCleaning_Click" Padding="10,5" HorizontalAlignment="Left"/>
                        <CheckBox Name="CbUrgent" Content="Chạy liên tục(không ước tính được)" VerticalAlignment="Center" HorizontalAlignment="Right" Checked="CbUrgent_Checked" Unchecked="CbUrgent_Unchecked"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="3. Chi tiết hóa đơn dịch vụ (ScrollBar)" Padding="15" Height="180" Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" ClipToBounds="True" Background="#F8F9FA">
                        <Canvas>
                            <StackPanel Name="BillPanel">
                                <StackPanel.RenderTransform>
                                    <TranslateTransform x:Name="BillTransform" Y="0"/>
                                </StackPanel.RenderTransform>

                                <TextBlock Text="1. Tiền phòng (3 ngày): 3.000.000đ" Margin="5"/>
                                <TextBlock Text="2. Coca Cola (Minibar) x2: 40.000đ" Margin="5"/>
                                <TextBlock Text="3. Mì ly (Minibar) x1: 25.000đ" Margin="5"/>
                                <TextBlock Text="4. Giặt ủi (Áo sơ mi): 50.000đ" Margin="5"/>
                                <TextBlock Text="5. Thuê xe máy (1 ngày): 150.000đ" Margin="5"/>
                                <TextBlock Text="6. Ăn sáng tại phòng: 120.000đ" Margin="5"/>
                                <TextBlock Text="7. Nước suối thêm x2: 20.000đ" Margin="5"/>
                                <TextBlock Text="8. Phí check-in sớm: 200.000đ" Margin="5"/>
                                <TextBlock Text="------------------------------------" Margin="5"/>
                                <TextBlock Text="TỔNG CỘNG: 3.605.000đ" FontWeight="Bold" Foreground="#1A73E8" Margin="5"/>
                            </StackPanel>
                        </Canvas>
                    </Grid>

                    <ScrollBar Name="SbBill" Grid.Column="1" Orientation="Vertical" ViewportSize="100"
                           Minimum="0" Maximum="150" Value="0" Scroll="SbBill_Scroll"/>
                </Grid>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</Window>